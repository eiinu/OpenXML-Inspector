{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenXML Inspector",
  "version": "0.1.0",
  "identifier": "me.eiinu.openxml-inspector",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenXML Inspector",
        "width": 1280,
        "height": 860,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.png"]
  }
}
